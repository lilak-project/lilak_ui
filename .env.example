# ──────────────────────────────────────────────────────────────────────────
#  lilak-ui — environment template (demo gallery only)
#
#  The kit itself is a library and needs no configuration. The only setting is
#  the port for the demo gallery (`npm run demo`).
#
#  HOW TO USE (optional, per machine)
#    1.  cp .env.example .env.local
#    2.  set PORT below
#    3.  npm run demo        (or just: PORT=5121 npm run demo)
#
#  .env.local is git-ignored; commit only this .env.example.
# ──────────────────────────────────────────────────────────────────────────

# Port for the demo gallery dev server. Default: 5120
PORT=5120
